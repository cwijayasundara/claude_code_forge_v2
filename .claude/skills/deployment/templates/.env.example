# ============================================================
# Environment Variables — copy to .env and fill in values
# ============================================================

# --- Required (app will not start without these) ---

# Anthropic API key for Claude document extraction
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL connection
POSTGRES_DB=app_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://postgres:changeme@db:5432/app_dev

# --- Optional (have sensible defaults) ---

# Backend
BACKEND_PORT=8000                     # default: 8000
LOG_LEVEL=info                        # default: info (debug, info, warning, error)
CORS_ORIGINS=http://localhost:3000    # default: http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:8000    # default: http://localhost:8000

# PDF Processing
MAX_UPLOAD_SIZE_MB=50                 # default: 50
OCR_ENABLED=true                      # default: true (fallback for scanned PDFs)
CONFIDENCE_THRESHOLD=0.8              # default: 0.8 (fields below this flagged for review)

# --- Test / CI only ---

# Set to "true" in CI to use recorded API responses instead of live Claude calls
USE_RECORDED_RESPONSES=false
