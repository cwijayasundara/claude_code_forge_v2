# Backend Development Dockerfile — Python 3.12 + FastAPI + hot reload
# Used by docker-compose.yml: backend service

FROM python:3.12-slim

WORKDIR /app

# System deps for build and runtime requirements
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast Python package management
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy dependency files first (cache layer)
COPY pyproject.toml ./
COPY uv.lock* ./

# Install Python dependencies
RUN uv sync --frozen --no-dev || uv sync --no-dev

# Copy source code (will be overridden by volume mount in dev)
COPY src/ ./src/

# Health check — FastAPI /health endpoint
HEALTHCHECK --interval=10s --timeout=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" || exit 1

EXPOSE 8000

# Dev server with hot reload (overridden in docker-compose.yml command)
CMD ["uv", "run", "uvicorn", "src.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
